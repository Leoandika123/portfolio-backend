{
    "version": 2,
    "framework": null,
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/api/test",
            "dest": "/api/test.php"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}